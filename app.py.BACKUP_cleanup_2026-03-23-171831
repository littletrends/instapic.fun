            "ok": False,
            "error": "local_create_ticket_disabled_use_motherpc"
        }), 410

    @app.route("/api/validate", methods=["POST"])
    def api_validate():
        return jsonify({
            "valid": False,
            "reason": "local_validate_disabled_use_motherpc"
        }), 410

    @app.route("/api/redeem", methods=["POST"])
